# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase Dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-anon-key" # Alias for anon key if used in some contexts

# Private key for server-side administrative tasks (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# -----------------------------------------------------------------------------
# Email Service (Resend)
# -----------------------------------------------------------------------------
# Get this from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# -----------------------------------------------------------------------------
# Payment Gateway (Midtrans)
# -----------------------------------------------------------------------------
# Get these from Midtrans Dashboard (Sandbox/Production)
MIDTRANS_MERCHANT_ID="your-merchant-id"
MIDTRANS_SERVER_KEY="your-server-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-client-key"
MIDTRANS_IS_PRODUCTION=false # Set to true for production environment

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------
# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID="G-..."

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# The base URL of your application
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Deployment (Vercel)
# -----------------------------------------------------------------------------
VERCEL_OIDC_TOKEN=""
